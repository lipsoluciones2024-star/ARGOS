# ==========================================================================
# ARGOS — Archivo de entorno de ejemplo
# Copiar a `.env` y ajustar. NINGUN secreto real debe commitearse.
# Toda configuración sensible viaja por variables de entorno (no hardcodeado).
# ==========================================================================

# --- Servidor -------------------------------------------------------------
# Host/puerto donde escucha el API REST + WebSocket.
ARGOS_SERVER_HOST=127.0.0.1
ARGOS_SERVER_PORT=8000

# --- Autenticación (OBLIGATORIO en producción) ----------------------------
# Token estático de admin usado por el CLI/UI. Si se omite, el servidor
# arranca en MODO INSEGURO (solo desarrollo, con advertencia en logs).
ARGOS_API_TOKEN=
# Secreto HMAC para firmar tokens de rol (operator/admin). Si se omite se
# deriva de data_dir; generar uno estable para no invalidar tokens en reinicio.
ARGOS_AUTH_SECRET=

# --- Cerebro LLM -----------------------------------------------------------
# Modo: hybrid | remote | local
ARGOS_LLM_MODE=hybrid

# Gateway de Kilo (gratuito, sin clave para modelos :free)
KILO_API_KEY=

# Proveedores directos (opcional, requieren claves)
CEREBRAS_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# --- Runtime local (modo LOCAL / fallback offline) ------------------------
# URL de un server OpenAI-compatible (llama.cpp / lm-format-enforcer).
ARGOS_LOCAL_BASE_URL=http://127.0.0.1:8080/v1
ARGOS_LOCAL_MODEL=local-gguf
# Ruta al GGUF relativa a models/ (usada por el bootstrap automático).
ARGOS_LOCAL_MODEL_PATH=models/qwen2.5-0.5b-instruct-q4_k_m.gguf

# --- Recolección -----------------------------------------------------------
ARGOS_AGENT_POLL_INTERVAL=5.0
ARGOS_RETENTION_DAYS=90

# --- Autonomía -------------------------------------------------------------
# Nivel inicial del switch: OBSERVE | SUGGEST | SEMI-AUTO | FULL-AUTO
ARGOS_DEFAULT_SWITCH=OBSERVE
# FULL_AUTO solo para lab. Advertencia auditable en el AuditLog.
